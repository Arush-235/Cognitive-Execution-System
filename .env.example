# .env — CES Configuration
# Copy to .env and fill in your API key

OPENAI_API_KEY=sk-your-key-here

# OpenAI model to use for task parsing, planning, and expansion.
# Recommended models (latest first):
#   gpt-5.3          - Best overall quality (reasoning + general tasks)
#   gpt-5.3-mini     - Faster, cheaper with strong performance
#   o3               - Strong reasoning-focused model
#   o4-mini          - Fast, efficient reasoning model
#   gpt-4.1          - Stable high-quality general model
#   gpt-4o           - Balanced multimodal model
#   gpt-4o-mini      - Fast, efficient multimodal model
OPENAI_MODEL=gpt-4o-mini

CES_DB_PATH=ces.db
